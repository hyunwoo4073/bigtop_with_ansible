groups:
  - name: platform-health
    rules:
      - alert: TargetDown
        expr: up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Prometheus target is down"
          description: "{{ '{{' }} $labels.job {{ '}}' }} target {{ '{{' }} $labels.instance {{ '}}' }} is down."

      - alert: HighMemoryUsage
        expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} memory usage is over 85%."

      - alert: HighDiskUsage
        expr: (1 - (node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"} / node_filesystem_size_bytes{fstype!~"tmpfs|overlay"})) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High disk usage"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} disk usage is over 85%."

      - alert: HDFSNameNodeJMXDown
        expr: up{job="hdfs-namenode-jmx"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HDFS NameNode JMX target down"
          description: "NameNode JMX exporter is not reachable."

      - alert: YARNResourceManagerJMXDown
        expr: up{job="yarn-resourcemanager-jmx"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "YARN ResourceManager JMX target down"
          description: "ResourceManager JMX exporter is not reachable."

      - alert: SparkHistoryServerJMXDown
        expr: up{job="spark-history-jmx"} == 0
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Spark History Server JMX target down"
          description: "Spark History Server JMX exporter is not reachable."

      - alert: NameNodeMetadataBackupMetricsMissing
        expr: absent(hdfs_namenode_backup_last_success_timestamp_seconds)
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "NameNode metadata backup metrics are missing"
          description: "NameNode metadata backup metric file is missing or Node Exporter textfile collector is not collecting it."

      - alert: NameNodeMetadataBackupFailed
        expr: hdfs_namenode_backup_success == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "NameNode metadata backup failed"
          description: "Last NameNode metadata backup failed on {{ '{{' }} $labels.instance {{ '}}' }}."

      - alert: NameNodeMetadataBackupStale
        expr: time() - hdfs_namenode_backup_last_success_timestamp_seconds > {{ hdfs_namenode_backup_max_age_seconds }}
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "NameNode metadata backup is stale"
          description: "NameNode metadata backup has not succeeded within the expected window on {{ '{{' }} $labels.instance {{ '}}' }}."

      - alert: HDFSNameNodeMetricsMissing
        expr: absent(hadoop_namenode_fsnamesystem_numlivedatanodes{job="hdfs-namenode-jmx"})
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "HDFS NameNode FSNamesystem metrics are missing"
          description: "NameNode JMX target is up, but FSNamesystem metrics are missing."

      - alert: HDFSLiveDataNodeLow
        expr: hadoop_namenode_fsnamesystem_numlivedatanodes{job="hdfs-namenode-jmx"} < {{ hdfs_expected_live_datanodes }}
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "HDFS live DataNode count is low"
          description: "Live DataNode count is below expected value. Expected={{ hdfs_expected_live_datanodes }}, current={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSDeadDataNodeDetected
        expr: hadoop_namenode_fsnamesystem_numdeaddatanodes{job="hdfs-namenode-jmx"} > 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HDFS dead DataNode detected"
          description: "One or more HDFS DataNodes are dead. Current dead DataNode count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSMissingBlocks
        expr: hadoop_namenode_fsnamesystem_missingblocks{job="hdfs-namenode-jmx"} > 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HDFS missing blocks detected"
          description: "HDFS has missing blocks. Current missing block count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSMissingReplicatedBlocks
        expr: hadoop_namenode_fsnamesystem_missingreplicatedblocks{job="hdfs-namenode-jmx"} > 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HDFS missing replicated blocks detected"
          description: "HDFS has missing replicated blocks. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSLowRedundancyBlocks
        expr: hadoop_namenode_fsnamesystem_lowredundancyblocks{job="hdfs-namenode-jmx"} > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HDFS low redundancy blocks detected"
          description: "HDFS has low redundancy blocks. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSLowRedundancyReplicatedBlocks
        expr: hadoop_namenode_fsnamesystem_lowredundancyreplicatedblocks{job="hdfs-namenode-jmx"} > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HDFS low redundancy replicated blocks detected"
          description: "HDFS has low redundancy replicated blocks. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSCorruptBlocks
        expr: hadoop_namenode_fsnamesystem_corruptblocks{job="hdfs-namenode-jmx"} > 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HDFS corrupt blocks detected"
          description: "HDFS has corrupt blocks. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSCorruptReplicatedBlocks
        expr: hadoop_namenode_fsnamesystem_corruptreplicatedblocks{job="hdfs-namenode-jmx"} > 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HDFS corrupt replicated blocks detected"
          description: "HDFS has corrupt replicated blocks. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSPendingReconstructionBlocks
        expr: hadoop_namenode_fsnamesystem_pendingreconstructionblocks{job="hdfs-namenode-jmx"} > 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "HDFS pending reconstruction blocks detected"
          description: "HDFS has pending reconstruction blocks for more than 10 minutes. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSExpiredHeartbeats
        expr: hadoop_namenode_fsnamesystem_expiredheartbeats{job="hdfs-namenode-jmx"} > 0
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "HDFS expired heartbeats detected"
          description: "NameNode has expired DataNode heartbeats. Current count={{ '{{' }} $value {{ '}}' }}."

      - alert: HDFSCapacityUsageHigh
        expr: (hadoop_namenode_fsnamesystem_capacityused{job="hdfs-namenode-jmx"} / hadoop_namenode_fsnamesystem_capacitytotal{job="hdfs-namenode-jmx"}) * 100 > {{ hdfs_capacity_warning_percent }}
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HDFS capacity usage is high"
          description: "HDFS capacity usage is over {{ hdfs_capacity_warning_percent }}%. Current={{ '{{' }} $value {{ '}}' }}%."

      - alert: HDFSCapacityUsageCritical
        expr: (hadoop_namenode_fsnamesystem_capacityused{job="hdfs-namenode-jmx"} / hadoop_namenode_fsnamesystem_capacitytotal{job="hdfs-namenode-jmx"}) * 100 > {{ hdfs_capacity_critical_percent }}
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "HDFS capacity usage is critical"
          description: "HDFS capacity usage is over {{ hdfs_capacity_critical_percent }}%. Current={{ '{{' }} $value {{ '}}' }}%."