global:
  resolve_timeout: 5m

route:
  receiver: "{{ 'slack-notifications' if alertmanager_slack_enabled else 'default-receiver' }}"
  group_by: ["alertname", "job", "instance"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 2h

receivers:
  - name: "default-receiver"

{% if alertmanager_slack_enabled %}
  - name: "slack-notifications"
    slack_configs:
      - api_url_file: "{{ alertmanager_slack_webhook_file }}"
        channel: "{{ alertmanager_slack_channel }}"
        send_resolved: true
        title: >-
          [{{ '{{' }} .Status | toUpper {{ '}}' }}] {{ '{{' }} .CommonLabels.alertname {{ '}}' }}
        text: >-
          {{ '{{' }} range .Alerts {{ '}}' }}
          *Severity:* `{{ '{{' }} .Labels.severity {{ '}}' }}`
          *Instance:* `{{ '{{' }} .Labels.instance {{ '}}' }}`
          *Job:* `{{ '{{' }} .Labels.job {{ '}}' }}`
          *Summary:* {{ '{{' }} .Annotations.summary {{ '}}' }}
          *Description:* {{ '{{' }} .Annotations.description {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}
{% endif %}